{
  "$schema": "../manifest.schema.json",
  "manifestVersion": 1,
  "id": "ai.msty.official.theme-terracotta-dusk",
  "name": "Terracotta Dusk",
  "version": "1.0.0",
  "description": "Sun-baked canyon walls at golden hour. Warm terracotta, burnt sienna, and sagebrush greens over a dusty desert backdrop. Canyon-shadow dark mode and a sun-washed adobe light mode. Tune the warmth, pick the accent stone, and feel the desert breathe.",
  "author": {
    "name": "Msty Team"
  },
  "license": "MIT",
  "icon": "static/icon.svg",
  "keywords": [
    "theme",
    "terracotta",
    "desert",
    "warm",
    "earth",
    "dark",
    "light"
  ],
  "categories": [
    "theme"
  ],
  "compatibility": {
    "extensionApi": "^1.0.0"
  },
  "permissions": [
    {
      "id": "themes.provide",
      "required": true,
      "reason": "Adds the Terracotta Dusk theme you can apply in Settings."
    }
  ],
  "contributes": {
    "themes": [
      {
        "id": "terracotta_dusk",
        "name": "Terracotta Dusk",
        "description": "Warm canyon walls at golden hour: terracotta, sienna, and sagebrush.",
        "previewImage": "static/terracotta-dusk-dark.jpg",
        "tokens": {
          "background.app": {
            "light": "#f5ebe0",
            "dark": "#1a110b"
          },
          "surface.sidebar": {
            "light": "rgba(237, 218, 198, 0.5)",
            "dark": "rgba(18, 12, 7, 0.42)"
          },
          "surface.sidebar.backdrop": "blur(14px) saturate(1.2)",
          "surface.sidebar.foreground": {
            "light": "#4a3425",
            "dark": "#d4b99a"
          },
          "surface.sidebar.border": {
            "light": "#d4b99a",
            "dark": "#3d2a1a"
          },
          "surface.sidebar.accent": {
            "light": "#e8d5bf",
            "dark": "#2d1c10"
          },
          "surface.sidebar.accent.foreground": {
            "light": "#3d2a1a",
            "dark": "#e8d5bf"
          },
          "surface.card": {
            "light": "#f8f0e2",
            "dark": "#221509"
          },
          "surface.popover": {
            "light": "#faf3e5",
            "dark": "#221509"
          },
          "surface.secondary": {
            "light": "#ebdcc8",
            "dark": "#2a1a0e"
          },
          "surface.secondary.foreground": {
            "light": "#3d2a1a",
            "dark": "#e8d5bf"
          },
          "surface.muted": {
            "light": "#f0e4d4",
            "dark": "#1e1209"
          },
          "surface.accent": {
            "light": "#e2cfb6",
            "dark": "#2d1c10"
          },
          "surface.accent.foreground": {
            "light": "#3d2a1a",
            "dark": "#e8d5bf"
          },
          "surface.input": {
            "light": "#d4b99a",
            "dark": "#4a2e18"
          },
          "surface.border": {
            "light": "#d4b99a",
            "dark": "#44301c"
          },
          "color.text": {
            "light": "#3d2a1a",
            "dark": "#e8d5bf"
          },
          "color.text.muted": {
            "light": "#8a7260",
            "dark": "#a08868"
          },
          "color.primary": {
            "light": "#b84629",
            "dark": "#e8834a"
          },
          "color.primary.foreground": {
            "light": "#ffffff",
            "dark": "#1a0e06"
          },
          "color.ring": {
            "light": "#b84629",
            "dark": "#e8834a"
          },
          "color.destructive": {
            "light": "#b83a2a",
            "dark": "#e85a3a"
          },
          "color.destructive.foreground": {
            "light": "#ffffff",
            "dark": "#1a0806"
          },
          "color.success": {
            "light": "#5a8a50",
            "dark": "#7db86a"
          },
          "color.success.foreground": {
            "light": "#ffffff",
            "dark": "#0a1a08"
          },
          "color.warning": {
            "light": "#a9760a",
            "dark": "#e8a840"
          },
          "color.warning.foreground": {
            "light": "#ffffff",
            "dark": "#1a1206"
          },
          "color.info": {
            "light": "#5a7a9a",
            "dark": "#8ab4d8"
          },
          "color.info.foreground": {
            "light": "#ffffff",
            "dark": "#0a1420"
          },
          "font.ui": "'Mulish', ui-sans-serif, system-ui, -apple-system, sans-serif",
          "font.mono": "'JetBrains Mono', ui-monospace, monospace",
          "font.google": "Mulish:wght@400;500;600;700, Fraunces:wght@400;500;600;700, Source Serif 4:wght@400;500;600, Space Grotesk:wght@400;500;600;700, Bitter:wght@400;500;600;700, JetBrains Mono:wght@400;500",
          "radius.control": "8px",
          "surface.assistant": "color-mix(in oklch, var(--card) 55%, transparent)",
          "surface.assistant.border": "color-mix(in oklch, var(--border) 30%, transparent)",
          "surface.assistant.backdrop": "blur(12px) saturate(1.2)",
          "surface.composer": "color-mix(in oklch, var(--card) 60%, transparent)",
          "surface.composer.backdrop": "blur(14px) saturate(1.2)"
        },
        "variables": {
          "--composer-radius": "14px",
          "--bubble-radius": "12px",
          "--popover-radius": "10px",
          "--pill-radius": "9999px",
          "--composer-shadow": {
            "light": "0 6px 24px rgba(120, 80, 40, 0.12)",
            "dark": "0 8px 30px rgba(0, 0, 0, 0.5)"
          },
          "--selection": {
            "light": "rgba(184, 70, 41, 0.22)",
            "dark": "rgba(232, 131, 74, 0.26)"
          },
          "--button-shadow": {
            "light": "0 2px 8px rgba(120, 80, 40, 0.15)",
            "dark": "0 2px 10px rgba(0, 0, 0, 0.4)"
          }
        },
        "assets": {
          "backgroundImageLight": "static/terracotta-dusk-light.jpg",
          "backgroundImageDark": "static/terracotta-dusk-dark.jpg"
        },
        "settings": {
          "title": "Terracotta Dusk options",
          "description": "Dial the warmth, pick the accent stone, and let the desert breathe.",
          "schema": {
            "type": "object",
            "properties": {
              "showBackground": {
                "type": "boolean",
                "title": "Show canyon",
                "description": "Sun-baked canyon wall artwork behind the workspace.",
                "default": true,
                "x-msty-order": 1,
                "x-msty-theme": [
                  {
                    "variable": "--app-background-image",
                    "values": {
                      "true": "{{backgroundImage}}",
                      "false": "none"
                    }
                  },
                  {
                    "variable": "--app-bg-overlay",
                    "values": {
                      "false": "transparent"
                    }
                  }
                ]
              },
              "canyonStrength": {
                "type": "number",
                "title": "Canyon depth",
                "description": "How strongly the canyon walls show through.",
                "default": 20,
                "minimum": 0,
                "maximum": 100,
                "multipleOf": 10,
                "x-msty-control": "slider",
                "x-msty-order": 2,
                "x-msty-visibleWhen": "showBackground",
                "x-msty-theme": {
                  "variable": "--app-background-opacity",
                  "value": "calc({{value}} / 100)"
                }
              },
              "accentStone": {
                "type": "string",
                "title": "Accent stone",
                "description": "The mineral vein running through the canyon.",
                "default": "copper",
                "enum": [
                  "copper",
                  "turquoise",
                  "sandstone"
                ],
                "x-msty-enum-labels": [
                  "Copper",
                  "Turquoise",
                  "Sandstone"
                ],
                "x-msty-control": "segmented",
                "x-msty-order": 3,
                "x-msty-theme": [
                  {
                    "variable": "--primary",
                    "values": {
                      "copper": "#b84629",
                      "turquoise": "#2a7c70",
                      "sandstone": "#8f6a2e"
                    }
                  },
                  {
                    "variable": "--ring",
                    "values": {
                      "copper": "#b84629",
                      "turquoise": "#2a7c70",
                      "sandstone": "#8f6a2e"
                    }
                  },
                  {
                    "variable": "--selection",
                    "values": {
                      "copper": "rgba(184, 70, 41, 0.22)",
                      "turquoise": "rgba(42, 124, 112, 0.22)",
                      "sandstone": "rgba(143, 106, 46, 0.22)"
                    }
                  }
                ]
              },
              "warmth": {
                "type": "integer",
                "title": "Warmth",
                "description": "How sun-baked the surfaces feel.",
                "default": 4,
                "minimum": 0,
                "maximum": 10,
                "multipleOf": 1,
                "x-msty-control": "slider",
                "x-msty-order": 4,
                "x-msty-theme": [
                  {
                    "variable": "--composer-surface",
                    "value": "color-mix(in oklch, color-mix(in srgb, var(--card), var(--primary) calc({{value}} * 1%)) 60%, transparent)"
                  },
                  {
                    "variable": "--assistant-surface",
                    "value": "color-mix(in oklch, color-mix(in srgb, var(--card), var(--primary) calc({{value}} * 0.8%)) 55%, transparent)"
                  },
                  {
                    "variable": "--composer-border",
                    "value": "color-mix(in srgb, var(--border), var(--primary) calc({{value}} * 1.6%))"
                  },
                  {
                    "variable": "--composer-border-focus",
                    "value": "color-mix(in srgb, var(--ring), var(--primary) calc({{value}} * 1.4%))"
                  },
                  {
                    "variable": "--assistant-border",
                    "value": "color-mix(in srgb, var(--border), var(--primary) calc({{value}} * 1.5%))"
                  },
                  {
                    "variable": "--composer-shadow",
                    "value": "0 8px 28px color-mix(in srgb, var(--primary) calc({{value}} * 1.3%), transparent)"
                  },
                  {
                    "variable": "--composer-shadow-focus",
                    "value": "0 10px 34px color-mix(in srgb, var(--primary) calc({{value}} * 1.5%), transparent)"
                  },
                  {
                    "variable": "--button-shadow",
                    "value": "0 2px 9px color-mix(in srgb, var(--primary) calc({{value}} * 0.8%), transparent)"
                  },
                  {
                    "variable": "--assistant-shadow",
                    "value": "0 5px 20px color-mix(in srgb, var(--primary) calc({{value}} * 0.8%), transparent)"
                  },
                  {
                    "variable": "--bubble-shadow",
                    "value": "0 4px 16px color-mix(in srgb, var(--primary) calc({{value}} * 0.8%), transparent)"
                  }
                ]
              },
              "uiFont": {
                "type": "string",
                "title": "Font",
                "description": "Typeface for the whole interface. All options load automatically.",
                "default": "mulish",
                "enum": [
                  "mulish",
                  "fraunces",
                  "sourceSerif",
                  "spaceGrotesk",
                  "bitter"
                ],
                "x-msty-enum-labels": [
                  "Mulish",
                  "Fraunces",
                  "Source Serif",
                  "Space Grotesk",
                  "Bitter"
                ],
                "x-msty-order": 5,
                "x-msty-theme": {
                  "variable": "--font-sans",
                  "values": {
                    "mulish": "'Mulish', ui-sans-serif, system-ui, -apple-system, sans-serif",
                    "fraunces": "'Fraunces', Georgia, 'Times New Roman', serif",
                    "sourceSerif": "'Source Serif 4', Georgia, 'Times New Roman', serif",
                    "spaceGrotesk": "'Space Grotesk', ui-sans-serif, system-ui, sans-serif",
                    "bitter": "'Bitter', Georgia, 'Times New Roman', serif"
                  }
                }
              }
            }
          }
        }
      }
    ]
  }
}
